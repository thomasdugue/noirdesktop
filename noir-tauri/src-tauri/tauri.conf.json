{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hean",
  "version": "0.2.0-beta.1",
  "identifier": "com.tdugue.hean",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Hean",
        "width": 1200,
        "height": 800,
        "minWidth": 320,
        "minHeight": 400,
        "decorations": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self' data: blob: noir: https://tauri.localhost; script-src 'self' noir: https://tauri.localhost; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: noir: https://tauri.localhost https://*.deezer.com https://*.scdn.co https://*.wikimedia.org; connect-src 'self' https://api.deezer.com https://musicbrainz.org https://coverartarchive.org https://commons.wikimedia.org https://github.com https://lrclib.net https://api.lyrics.ovh",
      "assetProtocol": {
        "enable": false
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/thomasdugue/noirdesktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc0NzNFRDAwODI0REQxOUIKUldTYjBVMkNBTzF6ZEk2ZldIby9GeXYzbDR0UFE4cFFHeVJvQXpsQTRvZlZwcE44VTRyWkNqL0kK"
    }
  }
}